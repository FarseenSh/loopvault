# LoopVault frontend env — copy to .env.local and fill in to enable zkLogin + gasless.
# Without these, the app still runs and falls back to wallet-extension connect.

# Network the dApp targets: testnet (default) or mainnet (Predict mainnet, day-1).
NEXT_PUBLIC_NETWORK=testnet

# Enoki PUBLIC API key — https://portal.enoki.mystenlabs.com (enoki_public_…).
# Public-safe: zkLogin + gas sponsorship are gated by the portal allowlist (which
# move-call targets may be sponsored), not by secrecy of this key.
NEXT_PUBLIC_ENOKI_API_KEY=

# Google OAuth 2.0 *Web* client id — https://console.cloud.google.com → Credentials.
# Add your app origin (e.g. http://localhost:3000/) as an Authorized redirect URI,
# and register the same Google client in the Enoki portal.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
